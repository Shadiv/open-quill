{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "declaration": false,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "test"]
}
