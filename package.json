{
  "name": "open-quill",
  "version": "0.1.0",
  "description": "OpenCode writing plugin: agents, commands, and writing tools",
  "type": "module",
  "license": "MIT",
  "author": "Shadiv",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "writing",
    "fiction",
    "editor",
    "prose",
    "canon",
    "russian"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shadiv/open-quill.git"
  },
  "homepage": "https://github.com/Shadiv/open-quill#readme",
  "bugs": {
    "url": "https://github.com/Shadiv/open-quill/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:build": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.1.1",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.2",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/diff": "^5.2.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.2.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
